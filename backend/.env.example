APP_ENV=development
HTTP_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
# Optional for hosted environments like Railway / Neon.
# If DATABASE_URL is set, it overrides DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD/DB_SSLMODE.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hrms
DB_USER=postgres
DB_PASSWORD=admin
DB_SSLMODE=disable
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
ADMIN_SEED_EMAIL=admin@northstar.id
ADMIN_SEED_PASSWORD=ChangeMe123!
